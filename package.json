		"@biomejs/biome": "2.4.7",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"colors": "^1.4.0",
		"discord.js": "^14.25.1",
		"zod": "^4.3.6"
	}
}