{
	"name": "postop-media",
	"module": "index.ts",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"deploy": "bun scripts/register_commands.ts",
		"format": "bunx --bun @biomejs/biome format --write",
